{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "时空任务编排器",
  "version": "0.1.0",
  "identifier": "local.mhxy.shikong.control",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "时空任务编排器",
        "width": 1460,
        "height": 880,
        "minWidth": 920,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
